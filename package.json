{
  "name": "vanderven-sys",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --persist-to ../.vanderven-wrangler-state --test-scheduled",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply vanderven-crm --local --persist-to ../.vanderven-wrangler-state",
    "db:migrate": "wrangler d1 migrations apply vanderven-crm --remote",
    "user": "node scripts/crm-user.mjs"
  },
  "devDependencies": {
    "wrangler": "^4.24.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "workerd@1.20260721.1": true
  }
}
